# HomeValue Nova — Environment Variables
# Copy this file to .env and fill in your values for local development.
# On Railway, set these directly in the service Variables panel.

# PostgreSQL connection string (provided automatically by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Agent notification phone numbers (E.164 format)
# English leads SMS goes to AGENT_PHONE_ENGLISH
AGENT_PHONE_ENGLISH=+1XXXXXXXXXX
# Spanish leads SMS goes to AGENT_PHONE_SPANISH
AGENT_PHONE_SPANISH=+1XXXXXXXXXX
# Legacy fallback (used if language-specific number is not set)
AGENT_PHONE_NUMBER=+1XXXXXXXXXX

# Public URL of the deployed app (used in SMS notifications)
DASHBOARD_URL=https://your-app.up.railway.app

# Server port (Railway sets this automatically)
PORT=3000
